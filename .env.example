# LLM CONFIGURATION (Gemini Pro)
# Get your key from: https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_pro_api_key_here
MODEL_NAME=gemini-3.1-pro-preview-customtools

# GITHUB APP CONFIGURATION
# Create a GitHub App in your Settings > Developer Settings
GITHUB_APP_ID=123456
GITHUB_WEBHOOK_SECRET=your_generated_webhook_secret

# The path to your GitHub App's private key (.pem file)
# In Docker, this usually maps to a volume like /app/secrets/key.pem
GITHUB_PRIVATE_KEY_PATH=./secrets/github_app_key.pem

# INFRASTRUCTURE & PERSISTENCE
# Redis is used by LangGraph to remember the state of your agents
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# APP SETTINGS
PORT=8000
LOG_LEVEL=info
ENVIRONMENT=development